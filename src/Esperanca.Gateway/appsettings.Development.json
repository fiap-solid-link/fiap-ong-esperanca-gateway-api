{
  "Swagger": {
    "Endpoints": [
      {
        "Url": "/swagger/identity/v1/swagger.json",
        "Name": "Identity API"
      }
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.AspNetCore": "Information",
        "Yarp": "Debug"
      }
    }
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000", "http://localhost:5173" ]
  },
  "HealthChecks": {
    "IdentityApi": {
      "Uri": "http://localhost:5017/health"
    }
  },
  "ReverseProxy": {
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5017"
          }
        }
      }
    }
  }
}
