{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Yarp": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName" ]
  },
  "AllowedHosts": "*",
  "Swagger": {
    "Endpoints": [
      {
        "Url": "/swagger/identity/v1/swagger.json",
        "Name": "Identity API"
      },
      {
        "Url": "/swagger/campanhas/v1/swagger.json",
        "Name": "Campanhas API"
      }
    ]
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000" ]
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowSeconds": 60
  },
  "HealthChecks": {
    "IdentityApi": {
      "Uri": "http://fiap-ong-esperanca-identity-api/health"
    },
    "CampanhasApi": {
      "Uri": "http://fiap-ong-esperanca-campanhas-api/health"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "identity-cluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/auth/{**catch-all}" }
        ]
      },
      "usuarios-route": {
        "ClusterId": "identity-cluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/api/usuarios/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/usuarios/{**catch-all}" }
        ]
      },
      "identity-swagger-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/swagger/identity/{**remainder}"
        },
        "Transforms": [
          { "PathPattern": "/swagger/{**remainder}" }
        ]
      },
      "identity-route": {
        "ClusterId": "identity-cluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/api/identity/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/identity/{**catch-all}" }
        ]
      },
      "campanhas-swagger-route": {
        "ClusterId": "campanhas-cluster",
        "Match": {
          "Path": "/swagger/campanhas/{**remainder}"
        },
        "Transforms": [
          { "PathPattern": "/swagger/{**remainder}" }
        ]
      },
      "campanhas-route": {
        "ClusterId": "campanhas-cluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/api/campanhas/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/campanhas/{**catch-all}" }
        ]
      },
      "doacoes-route": {
        "ClusterId": "campanhas-cluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/api/doacoes/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/doacoes/{**catch-all}" }
        ]
      },
      "transparencia-route": {
        "ClusterId": "campanhas-cluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/api/transparencia/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/transparencia/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://fiap-ong-esperanca-identity-api"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:10",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      },
      "campanhas-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://fiap-ong-esperanca-campanhas-api"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:10",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      }
    }
  }
}
